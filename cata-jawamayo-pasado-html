    <style>
        :root {
            --primary: #8c2b32; /* Tu color bordó */
            --bg: #faf9f6;
            --text: #1a1a1a;
            --text-light: #666;
            --radius: 16px;
        }

        * { box-sizing: border-box; margin: 0; padding: 0; }
        
        body { 
            font-family: 'Inter', sans-serif; 
            background-color: var(--bg); 
            color: var(--text); 
            line-height: 1.6;
            padding: 40px 20px;
        }

        .container { max-width: 800px; margin: 0 auto; }

        /* HEADER INTERNO */
        .back-link {
            text-decoration: none;
            color: var(--primary);
            font-weight: 600;
            font-size: 14px;
            display: inline-block;
            margin-bottom: 30px;
        }

        /* IMAGEN PRINCIPAL */
        .main-image {
            width: 100%;
            border-radius: var(--radius);
            box-shadow: 0 10px 30px rgba(0,0,0,0.05);
            margin-bottom: 30px;
            display: block;
        }

        /* CONTENIDO */
        .event-category {
            text-transform: uppercase;
            letter-spacing: 2px;
            font-size: 12px;
            color: var(--text-light);
            margin-bottom: 10px;
            display: block;
        }

        h1 {
            font-family: 'Lora', serif;
            font-size: 42px;
            line-height: 1.1;
            margin-bottom: 20px;
        }

        .event-meta {
            font-style: italic;
            color: var(--primary);
            margin-bottom: 30px;
            font-size: 18px;
        }

        .description {
            font-size: 17px;
            color: #444;
            margin-bottom: 40px;
        }

        .box-info {
            background: white;
            padding: 30px;
            border-radius: var(--radius);
            border: 1px solid #eee;
            text-align: center;
        }

        .btn {
            display: inline-block;
            padding: 15px 30px;
            background: var(--primary);
            color: white;
            text-decoration: none;
            border-radius: 12px;
            font-weight: 600;
            margin-top: 20px;
        }

        @media (max-width: 600px) {
            h1 { font-size: 32px; }
        }
    </style>
</head>
